<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>山科タイムトラベル探索</title>
    <style>
        body { background-color: #2c2c2c; color: #e0e0e0; font-family: "serif"; display: flex; justify-content: center; padding: 20px; }
        #game-container { width: 100%; max-width: 600px; background: #3d3d3d; padding: 20px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.5); }
        h1 { border-bottom: 2px solid #8b4513; padding-bottom: 10px; font-size: 1.5rem; }
        #message { margin-bottom: 20px; line-height: 1.6; min-height: 100px; }
        .button-group { display: flex; flex-direction: column; gap: 10px; }
        button { background: #8b4513; color: white; border: none; padding: 12px; cursor: pointer; border-radius: 4px; font-size: 1rem; transition: 0.3s; }
        button:hover { background: #a0522d; }
    </style>
</head>
<body>

<div id="game-container">
    <h1>昭和初期・山科探索</h1>
    <div id="message"></div>
    <div id="button-group" class="button-group"></div>
</div>

<script>
    const scenes = {
        start: {
            text: "あなたは昭和初期の山科駅に降り立ちました。まだ駅周辺には田畑が広がっています。どこへ向かいますか？",
            options: [
                { text: "琵琶湖疏水沿いを歩く", next: "sosui" },
                { text: "山科本願寺跡の土塁を探す", next: "honganji" }
            ]
        },
        sosui: {
            text: "疏水には、大津から京都へ物資を運ぶ『舟』がゆっくりと流れています。丘の上から景色を眺めていると、地元の古老に声をかけられました。",
            options: [
                { text: "当時の舟運について尋ねる", next: "info_boat" },
                { text: "南の勧修寺方面へ向かう", next: "kanshuji" }
            ]
        },
        honganji: {
            text: "巨大な土塁の跡に到着しました。今は畑になっていますが、かつての『城郭都市』としての面影が強く残っています。",
            options: [
                { text: "土塁の構造を詳しく調べる", next: "study_wall" },
                { text: "駅に戻る", next: "start" }
            ]
        },
        info_boat: {
            text: "「今はまだ舟が主役だが、もうすぐ鉄道の時代がもっと盛んになるだろう」と老人は語ります。貴重な証言を得ました。探索成功です！",
            options: [{ text: "最初から遊ぶ", next: "start" }]
        },
        kanshuji: {
            text: "勧修寺の門前に着きました。氷室の池の静かな風景が広がっています。この辺りはまだ静かな農村地帯です。",
            options: [{ text: "駅に戻る", next: "start" }]
        },
        study_wall: {
            text: "土塁の厚みに驚かされます。戦国時代からの防御遺構が、昭和の暮らしの中に溶け込んでいる様子を確認できました。探索成功です！",
            options: [{ text: "最初から遊ぶ", next: "start" }]
        }
    };

    function updateScene(sceneKey) {
        const scene = scenes[sceneKey];
        document.getElementById('message').innerText = scene.text;
        const buttonGroup = document.getElementById('button-group');
        buttonGroup.innerHTML = '';
        
        scene.options.forEach(option => {
            const btn = document.createElement('button');
            btn.innerText = option.text;
            btn.onclick = () => updateScene(option.next);
            buttonGroup.appendChild(btn);
        });
    }

    // 初回起動
    updateScene('start');
</script>

</body>
</html>
